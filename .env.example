# SkillLoop Environment Variables
# Copy this file to .env and fill in your values
# .env is blocked by .htaccess and must NOT be committed to git

DB_HOST=localhost
DB_NAME=skillloop
DB_USER=root
DB_PASS=your_database_password_here

# Set to 'production' to suppress PHP errors on screen
APP_ENV=development

# Optional: SMTP settings for real email sending
# MAIL_HOST=smtp.yourdomain.com
# MAIL_PORT=587
# MAIL_USER=noreply@yourdomain.com
# MAIL_PASS=your_smtp_password
# MAIL_FROM_NAME=SkillLoop